    "/api/JobApplications": {
      "post": {
        "tags": [
          "JobApplications"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "Email",
                  "Name",
                  "PhoneNumber",
                  "Resume"
                ],
                "type": "object",
                "properties": {
                  "JobId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "Name": {
                    "type": "string"
                  },
                  "Email": {
                    "type": "string",
                    "format": "email"
                  },
                  "PhoneNumber": {
                    "pattern": "^[0-9]{10}$",
                    "type": "string"
                  },
                  "CurrentLocation": {
                    "type": "string"
                  },
                  "Gender": {
                    "type": "string"
                  },
                  "TotalExperience": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "NoticePeriod": {
                    "type": "string"
                  },
                  "CurrentCTC": {
                    "type": "number",
                    "format": "double"
                  },
                  "ExpectedCTC": {
                    "type": "number",
                    "format": "double"
                  },
                  "Resume": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "JobId": {
                  "style": "form"
                },
                "Name": {
                  "style": "form"
                },
                "Email": {
                  "style": "form"
                },
                "PhoneNumber": {
                  "style": "form"
                },
                "CurrentLocation": {
                  "style": "form"
                },
                "Gender": {
                  "style": "form"
                },
                "TotalExperience": {
                  "style": "form"
                },
                "NoticePeriod": {
                  "style": "form"
                },
                "CurrentCTC": {
                  "style": "form"
                },
                "ExpectedCTC": {
                  "style": "form"
                },
                "Resume": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "JobApplications"
        ],
        "parameters": [
          {
            "name": "pageNumber",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
